      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0wjudb61d4bsup11a5tbf1m9yrvr].[ctd:hausse_prix_annoncee:qk]&quot;' value='Nb de hausses $' />
          <alias key='&quot;[federated.0wjudb61d4bsup11a5tbf1m9yrvr].[usr:Calculation_2853801157668864:qk]&quot;' value='% churn' />
        </aliases>
      </column>
      <column caption='Taux de churn' datatype='real' default-format='p0.0%' name='[Calculation_2853801157668864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([a_churne]) / COUNT([client_id])' />
      </column>
      <column caption='Nb de clients perdus' datatype='integer' name='[Calculation_2853801157775361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([a_churne])' />
      </column>
      <column caption='Clients à risque' datatype='integer' name='[Calculation_2853801158025218]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [a_churne] = 0 AND [score_risque_churn] &gt;= 0.60 THEN 1 ELSE 0 END' />
